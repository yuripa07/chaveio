# Copie para .env e preencha com seus valores
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
JWT_SECRET="gere-com-openssl-rand-base64-32"

# Google OAuth 2.0 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# User session signing secret — distinct from JWT_SECRET so either can be rotated independently
SESSION_SECRET="gere-com-openssl-rand-base64-32"
